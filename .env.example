# REZ HIVE Environment Configuration Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# REQUIRED: API Configuration
# ============================================
# Points to your FastAPI backend server
# Development: http://localhost:8001
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8001

# ============================================
# REQUIRED: LLM Configuration
# ============================================
# Ollama base URL (local inference)
OLLAMA_BASE_URL=http://localhost:11434

# Default model to use (must be available in Ollama)
# Examples: llama3.2, phi3.5:3.8b, mistral
OLLAMA_MODEL=llama3.2:latest

# ============================================
# REQUIRED: Search Configuration
# ============================================
# SearXNG instance URL for web search
SEARXNG_URL=http://localhost:8080

# Secret key for SearXNG (generate a random string in production)
# NEVER use default values in production
SEARXNG_SECRET_KEY=your-secure-random-key-here-min-32-chars

# ============================================
# OPTIONAL: Feature Flags
# ============================================
# Disable Turbopack bundler (set to 0 if using traditional bundler)
NEXT_TURBOPACK=0

# ============================================
# PRODUCTION ONLY: Observability
# ============================================
# Uncomment and configure for production deployments

# Error tracking (Sentry or similar)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Analytics (Google Analytics, Plausible, etc)
# NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX

# Backend logging endpoint
# API_LOGS_ENDPOINT=https://logs.yourdomain.com/api/logs

# ============================================
# SECURITY: What NOT to commit
# ============================================
# This file is a TEMPLATE only. 
# DO NOT commit actual values for:
#  - API keys or passwords
#  - Secret tokens
#  - Database credentials
#  - Third-party API keys
#
# Use .env.local for local development (git-ignored)
# Use GitHub Secrets for CI/CD environment variables
# Use your infrastructure's secrets manager (AWS Secrets Manager, HashiCorp Vault, etc) for production
